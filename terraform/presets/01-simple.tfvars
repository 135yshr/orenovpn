# =============================================================================
# プリセット ① 簡単・すぐ使える
# -----------------------------------------------------------------------------
# 方針: とにかく最短で動かす。編集するのは【認証情報4項目とSSH公開鍵】だけ。
#       セキュリティ機能（鍵認証のみ・fail2ban・自動更新）は既定で ON。
#       SSH はどこからでも接続可（鍵認証＋fail2ban で守る）。
#
# 向いている人: まず試したい / 接続元IPが変わる（外出先・モバイル回線）
# =============================================================================

# --- 認証情報（必須・ConoHa コントロールパネル → API）----------------------
conoha_tenant_name = "gnct00000000"
conoha_user_name   = "gncu00000000"
conoha_password    = "CHANGE_ME"

# --- SSH 公開鍵（必須・ssh-keygen で作成した .pub の中身）-------------------
ssh_public_key = "ssh-ed25519 AAAAC3Nza... CHANGE_ME"

# --- 初期作成するクライアント（任意）---------------------------------------
wg_clients = ["phone"]

# これ以降はすべて安全なデフォルト値が使われます:
#   ssh_port=22022 / SSH接続元=全開放 / fail2ban=ON / 自動更新=ON
#   WireGuard IPv6=ON / DNS=1.1.1.1,1.0.0.1 / フルトンネル
