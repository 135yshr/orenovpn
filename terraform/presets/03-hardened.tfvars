# =============================================================================
# プリセット ③ できうる最高のセキュア設定
# -----------------------------------------------------------------------------
# 方針: 攻撃面を最小化し、管理経路を厳格に絞る。
#       - SSH は高位ポート＋接続元を固定IPのみに厳格制限（必須）
#       - 管理ユーザー名を既定(vpnadmin)から変更（推測回避）
#       - WireGuard も非標準ポート
#       - DNS はプライバシー/セキュリティ重視の Quad9
#       - クライアントは最小限
#     ※ 一部の堅牢化（kill switch / auditd / クライアント側鍵生成）は
#       デプロイ後に docs/SECURITY.md の手順で実施すること。
#
# 向いている人: セキュリティ最優先 / 固定IPから管理できることが前提
# =============================================================================

# --- 認証情報（必須）--------------------------------------------------------
conoha_tenant_name = "gnct00000000"
conoha_user_name   = "gncu00000000"
conoha_password    = "CHANGE_ME"

# --- SSH 公開鍵（必須）------------------------------------------------------
ssh_public_key = "ssh-ed25519 AAAAC3Nza... CHANGE_ME"

# --- 管理ユーザー（既定名を避ける）-----------------------------------------
admin_user = "vpnops"

# --- SSH アクセス制御（厳格）-----------------------------------------------
ssh_port = 58022

# 【必須】管理用の固定IPのみ許可する。curl -4 ifconfig.co で確認して置換。
#   ここを 0.0.0.0/0 にすると本プリセットの意味が薄れる。
#   固定IPが無い場合は VPN 接続後に SSH する運用（wg_subnet 経由）も検討。
allowed_ssh_cidr = ["203.0.113.10/32"]

# --- WireGuard（非標準ポート + プライバシー重視DNS）------------------------
wg_port = 51930
wg_dns  = "9.9.9.9,149.112.112.112" # Quad9（DNSSEC検証・悪性ドメインブロック）

# --- セキュリティ機能 -------------------------------------------------------
enable_fail2ban     = true
enable_auto_updates = true

# --- 初期クライアントは最小限 ----------------------------------------------
wg_clients = ["phone"]

# =============================================================================
# デプロイ後に追加で実施（docs/SECURITY.md 参照）:
#   □ クライアント側の kill switch を有効化（VPN切断時の漏洩防止）
#   □ auditd を導入してログイン/権限昇格を記録
#   □ クライアント秘密鍵を端末側で生成（サーバーを経由させない）
#   □ Terraform state を暗号化リモートバックエンドで管理
# =============================================================================
